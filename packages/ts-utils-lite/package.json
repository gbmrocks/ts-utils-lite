{
  "name": "ts-utils-lite",
  "version": "0.0.3",
  "description": "Lightweight, type-safe utility library for web developers",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "dependencies": {
    "ts-string-lite": "0.0.1",
    "ts-array-lite": "0.0.3",
    "ts-date-lite": "0.0.1",
    "ts-object-lite": "0.0.1",
    "ts-number-lite": "0.0.1",
    "ts-validation-lite": "1.0.2",
    "ts-id-lite": "0.0.1",
    "ts-cookie-lite": "0.0.1"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "keywords": [
    "utils",
    "typescript",
    "javascript",
    "helpers",
    "lodash"
  ],
  "author": "Gaurang Mody - G8X",
  "license": "MIT"
}
