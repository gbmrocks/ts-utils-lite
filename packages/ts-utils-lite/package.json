{
  "name": "t1s-utils-lite",
  "version": "1.0.0",
  "description": "Lightweight, type-safe utility library for web developers",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    }
  },
  "dependencies": {
    "ts-string-lite": "*",
    "ts-array-lite": "*",
    "ts-date-lite": "*",
    "ts-object-lite": "*",
    "ts-number-lite": "*",
    "ts-validation-lite": "*",
    "ts-id-lite": "*",
    "ts-cookie-lite": "*"
  },
  "files": [
    "dist"
  ],
  "keywords": ["utils", "typescript", "javascript", "helpers", "lodash"],
  "author": "Gaurang Mody - G8X",
  "license": "MIT"
}
