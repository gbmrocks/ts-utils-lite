    "utils",
    "typescript",
    "storage",
    "localStorage",
    "sessionStorage",
    "lite"
  ],
  "author": "Gaurang Mody",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gbmrocks/ts-utils-lite.git"
  }
}
