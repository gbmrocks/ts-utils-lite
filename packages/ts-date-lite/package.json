{
  "name": "ts-date-lite",
  "version": "2.0.0",
  "description": "Lightweight, type-safe date utility library for web developers",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
