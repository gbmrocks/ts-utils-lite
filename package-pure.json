{
  "name": "ngx-utils-lite",
  "version": "1.0.0",
  "description": "Lightweight utility library for Angular and TypeScript",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["utils", "typescript", "angular", "javascript", "helpers"],
  "author": "Gaurang Mody - G8X",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}